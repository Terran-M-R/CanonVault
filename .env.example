# =============================================
# CanonVault — Environment Variables Template
# =============================================
# Copy this file to backend/.env and fill in all values.
# Never commit your actual .env file to GitHub.

# ----- Database (Supabase PostgreSQL) -----
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ----- Firebase Admin SDK (Backend Auth) -----
# Download your service account JSON from Firebase Console:
# Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ----- IBM watsonx.ai (Granite) -----
# Get from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your-watsonx-api-key
# Get from your watsonx.ai project settings
WATSONX_PROJECT_ID=your-watsonx-project-id
# Region endpoint — e.g. https://us-south.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ----- Hugging Face (Image Generation) -----
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# ----- Server -----
PORT=3001
NODE_ENV=development

# ----- Frontend (Vite) -----
# These go in frontend/.env (prefix with VITE_)
# VITE_API_URL=http://localhost:3001
# VITE_FIREBASE_API_KEY=your-firebase-web-api-key
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# VITE_FIREBASE_APP_ID=your-app-id
